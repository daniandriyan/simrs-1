# SIMRS Modern - Git Ignore File

# Environment files
.env
.env.local
.env.*.local

# Dependencies
/vendor/
composer.lock

# Storage files
/storage/cache/*
/storage/logs/*
/storage/sessions/*
!storage/cache/.gitkeep
!storage/logs/.gitkeep
!storage/sessions/.gitkeep

# Uploads
/public/uploads/*
!public/uploads/.gitkeep
/public/uploads/berkasrawat/
/public/uploads/photopasien/
/public/uploads/presensi/
/public/uploads/laboratorium/
/public/uploads/radiologi/
/public/uploads/invoices/

# IDE files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# Backup files
*.bak
*.backup
*.sql.gz
*.sql.bz2

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node.js (if using)
node_modules/
npm-debug.log
yarn-error.log

# Testing
.phpunit.result.cache
coverage/
.phpunit/

# Documentation
docs/_build/

# Sensitive files
config/production.php
config/secrets.php
*.key
*.pem
*.crt

# Database (SQLite)
*.sdb
*.sqlite
*.db

# Composer
composer.phar

# Build files
dist/
build/
